{
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "assets/*": ["./public/assets/*"],
      "components/*": ["./src/SceneController/components/*"],
      "hook/*": ["./src/SceneController/hook/*"],
      "data/*": ["./src/data/*"]
    },
    "checkJs": true,
    "target": "esnext",
    "lib": ["esnext", "DOM", "DOM.Iterable", "webworker"],
    "moduleResolution": "Bundler",
    "module": "esnext",
    "jsx": "react-jsx"
  },
  "exclude": ["node_modules", "dist", "public"]
}
